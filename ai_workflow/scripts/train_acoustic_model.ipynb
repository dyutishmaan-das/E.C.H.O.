{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 🦅 Project E.C.H.O. | 1D-CNN Raw Wave Model\n",
    "This model looks at raw microphone pulses directly, skipping the heavy FFT math."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {},
   "outputs": [],
   "source": [
    "import tensorflow as tf\n",
    "import os, librosa, numpy as np\n",
    "from sklearn.model_selection import train_test_split\n",
    "import kagglehub\n",
    "\n",
    "path = kagglehub.dataset_download(\"amineipad/drone-sound-audio-detection\")\n",
    "INPUT_LENGTH = 576 # 24x24 samples to match firmware\n",
    "\n",
    "def load_audio_chunks(folder, label_val, limit=2000):\n",
    "    X, y = [], []\n",
    "    files = [os.path.join(folder, f) for f in os.listdir(folder) if f.endswith('.wav')][:limit]\n",
    "    for f in files:\n",
    "        data, _ = librosa.load(f, sr=16000)\n",
    "        # Chop into chunks of 576 samples\n",
    "        for i in range(0, len(data) - INPUT_LENGTH, INPUT_LENGTH):\n",
    "            chunk = data[i:i+INPUT_LENGTH]\n",
    "            X.append(chunk)\n",
    "            y.append(label_val)\n",
    "    return X, y\n",
    "\n",
    "print(\"Loading Raw Audio Chunks...\")\n",
    "X_drone, y_drone = load_audio_chunks(os.path.join(path, 'Binary_Drone_Audio', 'yes_drone'), 1)\n",
    "X_none, y_none = load_audio_chunks(os.path.join(path, 'Binary_Drone_Audio', 'unknown'), 0)\n",
    "\n",
    "X = np.array(X_drone + X_none)[..., np.newaxis]\n",
    "y = np.array(y_drone + y_none)\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, stratify=y)\n",
    "print(f\"Dataset Ready: {X_train.shape}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1D-CNN Architecture (High Performance, Raw Input)\n",
    "model = tf.keras.Sequential([\n",
    "    tf.keras.layers.Conv1D(16, kernel_size=16, strides=4, activation='relu', input_shape=(INPUT_LENGTH, 1)),\n",
    "    tf.keras.layers.MaxPooling1D(pool_size=4),\n",
    "    tf.keras.layers.Conv1D(32, kernel_size=8, activation='relu'),\n",
    "    tf.keras.layers.GlobalAveragePooling1D(),\n",
    "    tf.keras.layers.Dense(1, activation='sigmoid')\n",
    "])\n",
    "\n",
    "model.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])\n",
    "model.fit(X_train, y_train, epochs=12, batch_size=64, validation_split=0.1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Export to Int8 Header\n",
    "converter = tf.lite.TFLiteConverter.from_keras_model(model)\n",
    "converter.optimizations = [tf.lite.Optimize.DEFAULT]\n",
    "def rep_data():\n",
    "    for f in X_train[:100]: yield [f.astype(np.float32).reshape(1, INPUT_LENGTH, 1)]\n",
    "converter.representative_dataset = rep_data\n",
    "converter.target_spec.supported_ops = [tf.lite.OpsSet.TFLITE_BUILTINS_INT8]\n",
    "converter.inference_input_type, converter.inference_output_type = tf.int8, tf.int8\n",
    "tflite_model = converter.convert()\n",
    "\n",
    "with open('echo_acoustic_model.h', 'w') as f:\n",
    "    f.write('const unsigned char echo_acoustic_model_tflite[] = {\\n ')\n",
    "    for i, byte in enumerate(tflite_model):\n",
    "        f.write(f'{byte:#04x}')\n",
    "        if i != len(tflite_model) - 1: f.write(', ')\n",
    "        if (i + 1) % 12 == 0: f.write('\\n ')\n",
    "    f.write('\\n};')\n",
    "\n",
    "print(f\"SUCCESS: 1D-Raw Model size: {len(tflite_model)/1024:.1f} KB\")"
   ]
  }
 ],
